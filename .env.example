# ─────────────────────────────────────────────────────────────
# Root dev environment — copy to .env to override defaults
# ─────────────────────────────────────────────────────────────

# Port for the game frontend (Vite). Auto-increments if taken.
# FRONTEND_PORT=5180

# Port for the local Cloudflare Worker (wrangler dev).
# Both the frontend proxy and admin proxy read this.
# API_PORT=8787
