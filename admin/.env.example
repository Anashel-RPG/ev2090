# ─────────────────────────────────────────────────────────────
# Admin Dashboard Environment Variables
# Copy to .env.local for local development
# ─────────────────────────────────────────────────────────────

# API base URL (optional — Vite proxy handles this in dev)
# In dev: proxied to production or local worker
# In prod: your worker URL
# VITE_API_URL=https://ws.ev2090.com

# Admin API key (optional — can also enter at login screen)
# VITE_FORGE_API_KEY=your_admin_api_key
